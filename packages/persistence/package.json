{
  "name": "@vingsforge/persistence",
  "version": "0.0.0",
  "private": true,
  "description": "SQLite persistence for VingsForge: schema, migrations and repositories behind a DbStore interface. Spec 08.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@vingsforge/shared": "workspace:*",
    "better-sqlite3": "^12.4.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^3.2.4",
    "@types/node": "^22.10.5",
    "@types/better-sqlite3": "^7.6.12"
  }
}
