{
  "name": "vingsforge",
  "version": "0.0.0",
  "private": true,
  "description": "VingsForge — desktop coding agent powered by Claude (Tauri 2 + Node sidecar + React). Linux-first.",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "dev:ui": "pnpm --filter @vingsforge/ui run dev",
    "dev:sidecar": "pnpm --filter @vingsforge/sidecar run dev"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
